generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model appointments {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id      String    @db.Uuid
  vehicle_id       String?   @db.Uuid
  assigned_user_id String?   @db.Uuid
  appointment_at   DateTime  @db.Timestamptz(6)
  status           String    @default("scheduled") @db.VarChar(20)
  notes            String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  users            users?    @relation(fields: [assigned_user_id], references: [id], onUpdate: NoAction)
  customers        customers @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  vehicles         vehicles? @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)

  @@index([customer_id], map: "idx_appointments_customer")
  @@index([appointment_at], map: "idx_appointments_date")
}

model brands {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique @db.VarChar(100)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  models     models[]
  vehicles   vehicles[]
}

model customers {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name             String                   @db.VarChar(100)
  last_name              String                   @db.VarChar(100)
  email                  String?                  @db.Citext
  phone                  String?                  @db.VarChar(30)
  address                String?
  city                   String?                  @db.VarChar(100)
  state                  String?                  @db.VarChar(100)
  zip_code               String?                  @db.VarChar(20)
  notes                  String?
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  appointments           appointments[]
  financing_applications financing_applications[]
  leads                  leads[]
  sales                  sales[]

  @@index([email], map: "idx_customers_email")
  @@index([phone], map: "idx_customers_phone")
}

model features {
  id               BigInt             @id @default(autoincrement())
  name             String             @unique @db.VarChar(100)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  vehicle_features vehicle_features[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model financing_applications {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id              String    @db.Uuid
  vehicle_id               String?   @db.Uuid
  status                   String    @default("pending") @db.VarChar(20)
  requested_amount         Decimal   @db.Decimal(12, 2)
  down_payment             Decimal   @default(0) @db.Decimal(12, 2)
  term_months              Int
  monthly_payment_estimate Decimal?  @db.Decimal(12, 2)
  lender_name              String?   @db.VarChar(150)
  notes                    String?
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime  @default(now()) @db.Timestamptz(6)
  customers                customers @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  vehicles                 vehicles? @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)

  @@index([customer_id], map: "idx_financing_customer")
  @@index([status], map: "idx_financing_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model leads {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String?               @db.Uuid
  vehicle_id          String?               @db.Uuid
  source              String?               @db.VarChar(50)
  status              String                @default("new") @db.VarChar(20)
  message             String?
  assigned_user_id    String?               @db.Uuid
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  lead_status_history lead_status_history[]
  users               users?                @relation(fields: [assigned_user_id], references: [id], onUpdate: NoAction)
  customers           customers?            @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  vehicles            vehicles?             @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)

  @@index([assigned_user_id], map: "idx_leads_assigned_user")
  @@index([customer_id], map: "idx_leads_customer_id")
  @@index([status], map: "idx_leads_status")
  @@index([vehicle_id], map: "idx_leads_vehicle_id")
}

model models {
  id         BigInt     @id @default(autoincrement())
  brand_id   BigInt
  name       String     @db.VarChar(100)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  brands     brands     @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  vehicles   vehicles[]

  @@unique([brand_id, name])
}

model roles {
  id          BigInt       @id @default(autoincrement())
  name        String       @unique @db.VarChar(50)
  description String?
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  user_roles  user_roles[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sales {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicle_id      String    @unique @db.Uuid
  customer_id     String    @db.Uuid
  sold_by_user_id String?   @db.Uuid
  sale_date       DateTime  @default(now()) @db.Timestamptz(6)
  sale_price      Decimal   @db.Decimal(12, 2)
  taxes           Decimal   @default(0) @db.Decimal(12, 2)
  fees            Decimal   @default(0) @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @db.Decimal(12, 2)
  payment_method  String?   @db.VarChar(30)
  notes           String?
  customers       customers @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  users           users?    @relation(fields: [sold_by_user_id], references: [id], onUpdate: NoAction)
  vehicles        vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)

  @@index([customer_id], map: "idx_sales_customer")
  @@index([sale_date], map: "idx_sales_sale_date")
}

model user_roles {
  user_id     String   @db.Uuid
  role_id     BigInt
  assigned_at DateTime @default(now()) @db.Timestamptz(6)
  roles       roles    @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
}

model users {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name              String                   @db.VarChar(150)
  email                  String                   @unique @db.Citext
  password_hash          String
  is_active              Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  appointments           appointments[]
  audit_logs             audit_logs[]
  lead_status_history    lead_status_history[]
  leads                  leads[]
  sales                  sales[]
  sessions               sessions[]
  user_permissions       user_permissions[]
  user_roles             user_roles[]
  vehicle_status_history vehicle_status_history[]
}

model vehicle_features {
  vehicle_id String   @db.Uuid
  feature_id BigInt
  features   features @relation(fields: [feature_id], references: [id], onUpdate: NoAction)
  vehicles   vehicles @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([vehicle_id, feature_id])
}

model vehicle_images {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicle_id String   @db.Uuid
  image_url  String
  is_primary Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  vehicles   vehicles @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vehicle_id, is_primary], map: "idx_vehicle_images_primary")
  @@index([vehicle_id], map: "idx_vehicle_images_vehicle_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vehicles {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stock_number           String                   @unique @db.VarChar(50)
  vin                    String?                  @unique @db.VarChar(17)
  brand_id               BigInt
  model_id               BigInt
  year                   Int                      @db.SmallInt
  color                  String?                  @db.VarChar(50)
  transmission           String?                  @db.VarChar(30)
  fuel_type              String?                  @db.VarChar(30)
  body_style             String?                  @db.VarChar(50)
  condition              String                   @default("used") @db.VarChar(20)
  mileage                Int                      @default(0)
  purchase_price         Decimal?                 @db.Decimal(12, 2)
  sale_price             Decimal                  @db.Decimal(12, 2)
  status                 String                   @default("available") @db.VarChar(20)
  description            String?
  location               String?                  @db.VarChar(150)
  acquired_at            DateTime?                @db.Date
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  appointments           appointments[]
  financing_applications financing_applications[]
  leads                  leads[]
  sales                  sales?
  vehicle_features       vehicle_features[]
  vehicle_images         vehicle_images[]
  vehicle_status_history vehicle_status_history[]
  brands                 brands                   @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  models                 models                   @relation(fields: [model_id], references: [id], onUpdate: NoAction)

  @@index([brand_id, model_id], map: "idx_vehicles_brand_model")
  @@index([sale_price], map: "idx_vehicles_price")
  @@index([status], map: "idx_vehicles_status")
  @@index([stock_number], map: "idx_vehicles_stock_number")
  @@index([year], map: "idx_vehicles_year")
}

model audit_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entity_id  String?
  old_data   Json?
  new_data   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model permissions {
  id               BigInt             @id @default(autoincrement())
  key              String             @unique @db.VarChar(100)
  name             String             @db.VarChar(150)
  description      String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  user_permissions user_permissions[]
}

model sessions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vehicle_status_history {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicle_id String   @db.Uuid
  old_status String?  @db.VarChar(20)
  new_status String   @db.VarChar(20)
  changed_by String?  @db.Uuid
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [changed_by], references: [id], onUpdate: NoAction)
  vehicles   vehicles @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lead_status_history {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id    String   @db.Uuid
  old_status String?  @db.VarChar(20)
  new_status String   @db.VarChar(20)
  changed_by String?  @db.Uuid
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [changed_by], references: [id], onUpdate: NoAction)
  leads      leads    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user_permissions {
  user_id       String      @db.Uuid
  permission_id BigInt
  can_access    Boolean     @default(true)
  granted_at    DateTime    @default(now()) @db.Timestamptz(6)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, permission_id])
}
